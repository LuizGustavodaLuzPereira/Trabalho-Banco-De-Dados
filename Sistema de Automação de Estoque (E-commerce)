-- =====================================================
-- Consulta de dados
-- =====================================================

-- WHERE
SELECT *
FROM produtos
WHERE estoque > 20;

-- LIKE
SELECT *
FROM clientes
WHERE nome LIKE '%Silva%';

-- BETWEEN
SELECT *
FROM produtos
WHERE preco BETWEEN 200 AND 1500;

-- ORDER BY
SELECT *
FROM produtos
ORDER BY preco DESC;

-- FUNÇÕES
SELECT COUNT(*) AS total_clientes
FROM clientes;

SELECT SUM(valor_total) AS faturamento
FROM pedidos;

SELECT AVG(preco) AS media_precos
FROM produtos;

-- RELATÓRIO COM JOIN
SELECT
    p.id_pedido,
    c.nome AS cliente,
    pr.nome AS produto,
    p.quantidade,
    p.valor_total,
    p.data_pedido
FROM pedidos p
INNER JOIN clientes c
ON p.id_cliente = c.id_cliente
INNER JOIN produtos pr
ON p.id_produto = pr.id_produto;

-- =====================================================
-- Triger
-- Reduzir o Estoque
-- =====================================================

DELIMITER $$

CREATE TRIGGER trg_baixa_estoque
AFTER INSERT ON pedidos
FOR EACH ROW
BEGIN
    UPDATE produtos
    SET estoque = estoque - NEW.quantidade
    WHERE id_produto = NEW.id_produto;
END $$

DELIMITER ;

