-- =====================================================

DELIMITER $$

CREATE PROCEDURE VerificarClienteVIP(
    IN p_cliente INT
)
BEGIN

    DECLARE total_compras DECIMAL(10,2);

    SELECT IFNULL(SUM(valor_total),0)
    INTO total_compras
    FROM pedidos
    WHERE id_cliente = p_cliente;

    IF total_compras > 500 THEN
        SELECT
            total_compras AS Total_Gasto,
            'CLIENTE VIP' AS Status_Cliente;
    ELSE
        SELECT
            total_compras AS Total_Gasto,
            'CLIENTE NORMAL' AS Status_Cliente;
    END IF;

END $$

DELIMITER ;

-- EXECUTAR PROCEDURE
CALL VerificarClienteVIP(1);

